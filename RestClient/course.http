### 3. Update a Course (Draft or Published)
# To update fields on specific batches (like ReservedExternally or seats), pass the entire batches array,
# ensuring you include the "_id" of each existing batch.'

POST {{baseUrl}}/course/edit/{{courseId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "courseTitle": "Mastering Advanced Node.js 2026 (Updated)",
  "shortdesc": "Updated summary of backend development master class.",
  "oneMonthPassPrice": 150.00,
  "oneMonthPassEnabled": true,
  "threeMonthPassPrice": 400.00,
  "threeMonthPassEnabled": true,
  "batches": [
    {
      "_id": "6a2904769f3feca6e22f5917",
      "ReservedExternally": 10
    },
    {
      "_id": "6a2904769f3feca6e22f5918", 
      "ReservedExternally": 2
    }
  ]
}


