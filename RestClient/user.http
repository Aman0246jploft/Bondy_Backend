### Environment Variables
@baseUrl = http://localhost:8080/api/v1



### 9. Admin Direct Login

POST {{baseUrl}}/user/admin/login
Content-Type: application/json

{
  "email": "superadmin@mailinator.com",
  "password": "123456"
}


### ----------------------------------------------------
### CUSTOMER SIGNUP FLOW
### ----------------------------------------------------

### 1. Customer Signup Step 1 (Init - Triggers OTP)
POST {{baseUrl}}/user/customer/signup
Content-Type: application/json

{
  "email": "customer@example.com",
  "countryCode": "+1",
  "contactNumber": "1234567890",
  "password": "Password123!",
  "confirmPassword": "Password123!",
  "fmcToken": "sample_fmc_token_123"
}

### 2. Customer Signup Step 2 (Verify OTP & Register)
# Note: In development mode, the OTP is default to "12345"
# Uses the single global/universal verify-otp endpoint with type = "CUSTOMER".
POST {{baseUrl}}/user/verify-otp
Content-Type: application/json

{
  "email": "customer@example.com",
  "otp": "12345",
  "type": "CUSTOMER"
}

### 3. Customer Resend Signup OTP
POST {{baseUrl}}/user/resend-otp
Content-Type: application/json

{
  "email": "customer@example.com"
}


### ----------------------------------------------------
### ORGANIZER SIGNUP FLOW
### ----------------------------------------------------

### 4. Organizer Signup Step 1 (Init - Triggers OTP)
POST {{baseUrl}}/user/organizer/signup
Content-Type: application/json

{
  "fullname": "Test Organizer",
  "email": "testOrganizer6@example.com",
  "countryCode": "+91",
  "contactNumber": "9005267079",
  "password": "password123",
  "confirmPassword": "password123",
  "acceptTerms": true,
  "referralCode": "",
  "fmcToken": "sample_fmc_token_456"
}

### 5. Organizer Signup Step 2 (Verify OTP & Register)
# Note: In development mode, the OTP is default to "12345"
# Uses the single global/universal verify-otp endpoint with type = "ORGANIZER".
POST {{baseUrl}}/user/verify-otp
Content-Type: application/json

{
  "email": "testorg90@yopmail.com",
  "otp": "12345",
  "type": "ORGANIZER"
}


### ----------------------------------------------------
### LOGIN FLOW (With 2FA OTP)
### ----------------------------------------------------

### 6. User Login Step 1 (Init - Triggers Login OTP)
# Set type as "CUSTOMER" or "ORGANIZER" based on role type
POST {{baseUrl}}/user/login/init
Content-Type: application/json

{
  "email": "testorg90@yopmail.com",
  "password": "Test@123",
  "type": "ORGANIZER"
}

### 7. User Login Step 2 (Verify Login OTP)
# Note: In development mode, the OTP is default to "12345"
# Uses the single global/universal verify-otp endpoint with type = "LOGIN".
POST {{baseUrl}}/user/verify-otp
Content-Type: application/json

{
  "email": "testorg90@yopmail.com",
  "otp": "12345",
  "type": "LOGIN"
}

### 8. Resend Login OTP
POST {{baseUrl}}/user/login/resend-otp
Content-Type: application/json

{
  "email": "customer@example.com"
}


### ----------------------------------------------------
### SOCIAL LOGIN FLOWS
### ----------------------------------------------------

### 10. Social Login
POST {{baseUrl}}/user/social-login
Content-Type: application/json

{
  "socialId": "fb_1234567890",
  "socialType": "facebook",
  "type": "CUSTOMER",
  "email": "facebookuser@example.com",
  "firstName": "Jane",
  "lastName": "Smith",
  "profileImage": "https://example.com/jane.jpg"
}


### ----------------------------------------------------
### ORGANIZER PROFILE & BUSINESS INFO UPDATES
### ----------------------------------------------------

### 11. Organizer Update Business Info
# Authenticated organizer submits/updates business name, category, short desc, and social media link.
# Note: This will set the account review status to "pending" for admin review/approval.
@organizerToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI2YTMyOTFmNDZhOTAwMDQyMWVjNzYyMjIiLCJyb2xlSWQiOjIsImlhdCI6MTc4MTg3NDEzOCwiZXhwIjoyNjQ1ODc0MTM4fQ.bdHXpekE-IfKeF5GTfuvBrM5IuBzsD4gXp8zhP-1mhk
@categoryId = 647f1234567890abcdef1234
POST {{baseUrl}}/user/organizer/info
Authorization: Bearer {{organizerToken}}
Content-Type: application/json

{
  "businessName": "Updated Business Name Ltd",
  "category": "{{categoryId}}",
  "shortDesc": "We updated our business description to offer even better events.",
  "socialMediaLink": "https://instagram.com/updatedbusiness"
}


### 12. Update Profile & Business Info (Universal Profile Update)
# Update standard fields (name, profile image, contact, location) and/or organizer business fields.
POST {{baseUrl}}/user/update-profile
Authorization: Bearer {{organizerToken}}
Content-Type: application/json

{
  # "firstName": "Alex",
  # "lastName": "Organizer",
  # "profileImage": "uploads/profile/organizer1.jpg",
  # "contactNumber": "9876543210",
  # "countryCode": "+1",
  # "location": {
  #   "latitude": 40.7128,
  #   "longitude": -74.0060,
  #   "city": "New York",
  #   "country": "USA",
  #   "address": "123 Event Street"
  # },
  "businessName": "Updated Business Name Ltd",
   "businessCategory": "{{categoryId}}",
   "shortDesc": "We updated our business description directly through the profile update endpoint.",
  "socialMediaLink": "https://instagram.com/updatedbusiness"
}


### 13. Get My Profile
GET {{baseUrl}}/user/selfProfile
Authorization: Bearer {{organizerToken}}
Content-Type: application/json



### 13. Get My Profile
GET {{baseUrl}}/user/profile/6a1e80665979beee41cf5f4b
Authorization: Bearer {{organizerToken}}
Content-Type: application/json