### ----------------------------------------------------
### 1. PHONE OTP VERIFICATION FLOW
### ----------------------------------------------------

### Step 1.1: Send OTP to Phone
POST {{baseUrl}}/verification/phone/send-otp
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "countryCode": "+91",
  "contactNumber": "9005267079"
}

### Step 1.2: Resend OTP to Phone
POST {{baseUrl}}/verification/phone/resend-otp
Authorization: Bearer {{userToken}}
Content-Type: application/json

{}

### Step 1.3: Verify Phone OTP
# Note: OTP defaults to "12345" in development mode
POST {{baseUrl}}/verification/phone/verify-otp
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "otp": "12345"
}


### ----------------------------------------------------
### 2. EMAIL OTP VERIFICATION FLOW
### ----------------------------------------------------

### Step 2.1: Send OTP to Email
POST {{baseUrl}}/verification/email/send-otp
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "email": "testOrganizer@example.com"
}

### Step 2.2: Resend OTP to Email
POST {{baseUrl}}/verification/email/resend-otp
Authorization: Bearer {{userToken}}
Content-Type: application/json

{}

### Step 2.3: Verify Email OTP
# Note: OTP defaults to "12345" in development mode
POST {{baseUrl}}/verification/email/verify-otp
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "otp": "12345"
}


### ----------------------------------------------------
### 3. ID VERIFICATION SUBMISSIONS (ORGANIZER)
### ----------------------------------------------------

### Step 3.1: Submit National ID Verification
POST {{baseUrl}}/verification/submit
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "nationalId": {
    "frontImage": "cloudinary_front_national_id_image_url",
    "backImage": "cloudinary_back_national_id_image_url"
  }
}

### Step 3.2: Submit Driving Licence Verification
POST {{baseUrl}}/verification/submit
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "drivingLicence": {
    "frontImage": "cloudinary_front_driving_licence_image_url",
    "backImage": "cloudinary_back_driving_licence_image_url"
  }
}

### Step 3.3: Submit ID Verification as a Nested Object
POST {{baseUrl}}/verification/submit
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "idVerification": {
    "nationalId": {
      "frontImage": "nested_front_national_id",
      "backImage": "nested_back_national_id"
    },
    "drivingLicence": {
      "frontImage": "nested_front_licence",
      "backImage": "nested_back_licence"
    }
  }
}

### Step 3.4: Submit ID Verification as an Array
POST {{baseUrl}}/verification/submit
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "idVerification": [
    {
      "type": "nationalId",
      "frontImage": "array_front_national_id",
      "backImage": "array_back_national_id"
    },
    {
      "type": "drivingLicence",
      "frontImage": "array_front_licence",
      "backImage": "array_back_licence"
    }
  ]
}


### ----------------------------------------------------
### 4. BANK VERIFICATION SUBMISSION (ORGANIZER)
### ----------------------------------------------------

### Step 4.1: Submit Bank Account Verification
POST {{baseUrl}}/verification/submit
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "bankVerification": {
    "bankName": "State Bank of India",
    "bankHolderName": "Test Organizer",
    "accountNumber": "999912345678",
    "otherDetails": "SBIN0001234"
  }
}


### ----------------------------------------------------
### 5. GET REQUESTS & AUDIT FLOW (ADMIN)
### ----------------------------------------------------

### Step 5.1: Get All Pending Verification Requests
GET {{baseUrl}}/verification/requests?status=pending&page=1&limit=10
Authorization: Bearer {{adminToken}}

### Step 5.2: Admin Approves National ID Verification
# Note: Approving the ID verification immediately flags user.isVerified = true
POST {{baseUrl}}/verification/audit
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "userId": "{{organizerUserId}}",
  "type": "nationalId",
  "action": "approve"
}

### Step 5.3: Admin Rejects Driving Licence Verification
POST {{baseUrl}}/verification/audit
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "userId": "{{organizerUserId}}",
  "type": "drivingLicence",
  "action": "reject",
  "reason": "The uploaded images are blurred and unreadable."
}

### Step 5.4: Admin Approves Bank Account Verification
# Note: Approving bank details automatically synchronizes them to the legacy bankDetails schema for compatibility.
POST {{baseUrl}}/verification/audit
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "userId": "{{organizerUserId}}",
  "type": "bankVerification",
  "action": "approve"
}
