	"item": [
		{
			"name": "1. Organizer Filters",
			"item": [
				{
					"name": "Fetch Organizer Events (Newest First)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/event/list?filter=organizer",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"event",
								"list"
							],
							"query": [
								{
									"key": "filter",
									"value": "organizer",
									"description": "Restricts events to those created by the logged-in organizer."
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Filter Organizer Events - Drafts Only",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/event/list?filter=organizer,draft",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"event",
								"list"
							],
							"query": [
								{
									"key": "filter",
									"value": "organizer,draft",
									"description": "Filters only draft events created by the organizer."
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Filter Organizer Events - Published Only",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/event/list?filter=organizer&isDraft=false",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"event",
								"list"
							],
							"query": [
								{
									"key": "filter",
									"value": "organizer"
								},
								{
									"key": "isDraft",
									"value": "false"
								}
							]
						}
					},
					"response": []
				}
			]
		},
